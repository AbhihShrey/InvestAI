# InvestAI – copy to config/.env and fill in. Do not commit config/.env or config/.schwab_token.json.
# All tools (backend, fetch jobs, token generator) load from config/.env when present.
# If you had scripts/.env or scripts/.schwab_token.json, copy them here as config/.env and config/.schwab_token.json.

# --- Backend ---
# Database URL. Leave unset for local SQLite at backend/app.db (absolute path).
# Or set to a path; relative paths (e.g. ./backend/app.db) are resolved from repo root.
# DATABASE_URL=sqlite+aiosqlite:///./backend/app.db

# JWT secret for dashboard login. Set a strong random value in production.
# AUTH_JWT_SECRET=change-me-in-production

# --- Frontend ---
# Set in frontend/.env.local as NEXT_PUBLIC_API_URL for build-time
# NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Schwab API (https://developer.schwab.com/) ---
# Required: app key and secret from developer portal
SCHWAB_API_KEY=your_api_key_here
SCHWAB_APP_SECRET=your_app_secret_here

# Token file path (relative to repo root). Generate once: python -m app.schwab.generate_token
# Token will be written to config/.schwab_token.json if this is set to config/.schwab_token.json
SCHWAB_TOKEN_PATH=config/.schwab_token.json

# Optional: use SCHWAB_TOKEN_JSON instead of file (e.g. serverless). JSON string of full token object.
# SCHWAB_TOKEN_JSON={"creation_timestamp":...,"token":{...}}
