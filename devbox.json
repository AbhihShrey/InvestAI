{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": [
    "gh@2.87.3",
    "python@3.12",
    "nodejs@22",
    "python312Packages.pip@25.0.1"
  ],
  "shell": {
    "init_hook": [
      "python -m venv .venv",
      ".venv/bin/pip install --upgrade pip"
    ],
    "scripts": {
      "install-deps": "[ -d .venv ] || python -m venv .venv && .venv/bin/pip install --upgrade pip && .venv/bin/pip install -e backend[schwab] && (cd backend && ../.venv/bin/alembic upgrade head)",
      "dev:backend": "cd backend && PYTHONPATH=. ../.venv/bin/uvicorn app.main:app --reload",
      "dev:frontend": "cd frontend && npm run dev",
      "fetch:prices": "PYTHONPATH=backend .venv/bin/python -m app.schwab.fetch_bulk --default",
      "generate-token": "PYTHONPATH=backend .venv/bin/python -m app.schwab.generate_token"
    }
  }
}
